import React from "react"; export default function LanguageSwitcher({ lang, setLang }) { return ( <div className="flex gap-2 
    items-center">
      <button className={`px-3 py-1 rounded ${lang === 'ar' ? 'bg-blue-600 text-white' : 'bg-gray-200'}`} onClick={() => setLang('ar')}
      >العربية</button>
      <button className={`px-3 py-1 rounded ${lang === 'en' ? 'bg-blue-600 text-white' : 'bg-gray-200'}`} onClick={() => setLang('en')}
      >English</button>
    </div> );
}
