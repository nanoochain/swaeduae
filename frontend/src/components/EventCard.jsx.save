import React from "react"; export default function EventCard({ title, desc, location, date, time, category, img, volunteers }) { return ( 
    <div className="min-w-[320px] max-w-xs bg-white shadow rounded-2xl overflow-hidden flex flex-col relative">
      <img src={img} alt={title} className="h-40 object-cover w-full" /> <div className="p-4 flex-1 flex flex-col"> <span 
        className="absolute top-3 right-3 bg-purple-600 text-white rounded px-2 py-1 text-xs">{category}</span> <h3 className="font-bold 
        text-lg mb-1">{title}</h3> <div className="text-gray-600 text-sm line-clamp-2">{desc}</div> <div className="text-xs text-blue-700 
        mt-2">
          <span className="block"><i className="fas fa-map-marker-alt"></i> {location}</span> <span className="block"><i className="fas 
          fa-calendar-alt"></i> {date}</span> <span className="block"><i className="fas fa-clock"></i> {time}</span> <span 
          className="block"><i className="fas fa-users"></i> {volunteers} عدد المتطوعين</span>
        </div> <button className="mt-3 w-full bg-blue-900 hover:bg-blue-800 text-white rounded font-bold py-2 transition"> سجل الآن 
        </button>
      </div> </div> );
}
