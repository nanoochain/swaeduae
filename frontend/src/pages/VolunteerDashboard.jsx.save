import React from "react"; import { Link } from "react-router-dom"; export default function VolunteerDashboard() { return ( <div 
    className="p-8">
      <h1 className="text-3xl font-bold mb-6">لوحة تحكم المتطوع</h1> <div className="grid grid-cols-1 md:grid-cols-3 gap-8"> <Link 
        to="/profile" className="card hover:shadow-lg p-6 rounded-xl border text-center">
          <div className="text-5xl mb-2">👤</div> <div>الملف الشخصي</div> </Link> <Link to="/my-events" className="card hover:shadow-lg 
        p-6 rounded-xl border text-center">
          <div className="text-5xl mb-2">📅</div> <div>فعالياتي</div> </Link> <Link to="/certificates" className="card hover:shadow-lg p-6 
        rounded-xl border text-center">
          <div className="text-5xl mb-2">📜</div> <div>شهاداتي</div> </Link> <Link to="/feedback" className="card hover:shadow-lg p-6 
        rounded-xl border text-center">
          <div className="text-5xl mb-2">📝</div> <div>تقييم الفعاليات</div> </Link> </div> </div> );
}
