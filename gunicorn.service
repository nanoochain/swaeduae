[Unit]
Description=Gunicorn instance to serve swaeduae backend
After=network.target

[Service]
User=root
Group=www-data
WorkingDirectory=/opt/swaeduae/backend
Environment="PATH=/opt/swaeduae/backend/venv/bin"
ExecStart=/opt/swaeduae/backend/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 app:app

[Install]
WantedBy=multi-user.target