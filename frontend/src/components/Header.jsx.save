    bg-blue-900 bg-opacity-90 text-white py-2 shadow sticky top-0 z-50">
      <div className="container mx-auto flex items-center justify-between px-4"> <Link to="/" className="flex items-center font-bold 
        text-2xl tracking-tight">
          <img src="/logo.svg" alt="SwaedUAE" className="h-10 mr-2" /> متطوعي الإمارات </Link> <nav className="hidden md:flex gap-6 
        font-medium">
          <Link to="/" className="hover:text-orange-400">الرئيسية</Link> <Link to="/about" className="hover:text-orange-400">عن 
          المنصة</Link> <Link to="/events" className="hover:text-orange-400">الفرص التطوعية</Link> <Link to="/partners" 
          className="hover:text-orange-400">شركاء</Link> <Link to="/faq" className="hover:text-orange-400">الأسئلة الشائعة</Link> <Link 
          to="/contact" className="hover:text-orange-400">تواصل معنا</Link>
        </nav> <div className="flex gap-2 items-center"> <button className="bg-orange-500 text-white rounded px-3 py-1 font-bold 
          hover:bg-orange-600 transition">
            تسجيل الدخول </button> <select className="bg-blue-800 border-none text-white px-2 py-1 rounded"> <option 
            value="ar">العربية</option> <option value="en">English</option>
          </select> <button className="md:hidden ml-2"> <svg width="26" height="26" fill="currentColor" viewBox="0 0 20 20"> <path d="M3 
              6h14M3 12h14M3 18h14" />
            </svg> </button> </div> </div> </header> );
