<?php

use Illuminate\Support\Facades\Route;

// --- Controller Imports (only once each) ---
use App\Http\Controllers\EventController;
use App\Http\Controllers\OpportunityController;
use App\Http\Controllers\CertificateController;
use App\Http\Controllers\DashboardController;
use App\Http\Controllers\PagesController;
use App\Http\Controllers\HomeController;
use App\Http\Controllers\Auth\RegisterController;

// --- Key Resource Routes ---

// Home
Route::get('/', function () {
    return view('home');
})->name('home');

// Events (only once, with both names: events.index & events.list)
Route::get('/events', [EventController::class, 'index'])->name('events.index');
Route::get('/events', [EventController::class, 'index'])->name('events.list');

// Opportunities
Route::get('/opportunities', [OpportunityController::class, 'index'])->name('opportunities.index');

// Certificates
Route::get('/certificates', [CertificateController::class, 'index'])->name('certificates.index');

// Dashboard
Route::get('/dashboard', [DashboardController::class, 'index'])->name('dashboard');

// Partners
Route::get('/partners', [PagesController::class, 'partners'])->name('partners');

// --- Register route for Laravel UI or Breeze/Jetstream ---
Route::get('/register', [RegisterController::class, 'showRegistrationForm'])->name('register');
Route::post('/register', [RegisterController::class, 'register']);

// --- Add any other custom/app routes below here ---

