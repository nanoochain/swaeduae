import React, { useEffect, useState } from "react";import React from "react"; export default function Resources() { export default 
function Resources() { // TODO: Fetch/downloadable files
  const [resources, setResources] = useState([]); return ( <div className="max-w-3xl mx-auto py-12 px-6"> useEffect(()=>{ 
  fetch("/api/resources").then(r=>r.json()).then(setResources); }, []); <h2 className="text-2xl font-bold mb-6">مركز الموارد</h2> return ( 
  <ul className="list-disc pl-6">
    <div className="max-w-4xl mx-auto mt-10"> <li><a href="#" className="text-blue-700 underline">دليل التطوع في الإمارات (PDF)</a></li> 
        <li><a href="#" className="text-blue-700 underline">سياسة التطوع الوطنية</a></li> <li><a href="#" className="text-blue-700 
        underline">نماذج طلب الفعالية</a></li>
      <h1 className="text-3xl font-bold mb-6">مركز الموارد</h1> </ul> </div> <div className="grid grid-cols-1 md:grid-cols-2 gap-6"> ); 
        {resources.map(res=>(}
          <a key={res.id} href={res.link} target="_blank" rel="noopener noreferrer" className="bg-white rounded-2xl p-6 shadow flex 
             flex-col gap-3 hover:bg-blue-50">
            <div className="font-bold text-lg">{res.title}</div> <div className="text-gray-500">{res.type}</div> <div 
            className="text-sm">{res.description}</div>
          </a> ))} </div> </div> );
}
