import React, { useEffect, useState } from "react";import React from "react"; export default function News() { import { Link } from 
"react-router-dom"; // TODO: Fetch news from API export default function News() { return (
  const [articles, setArticles] = useState([]); <div className="max-w-4xl mx-auto py-10 px-6"> <h2 className="text-2xl font-bold 
      mb-6">الأخبار والمستجدات</h2> <div className="grid md:grid-cols-2 gap-8">
  useEffect(()=>{ fetch("/api/news").then(r=>r.json()).then(setArticles); }, []); {[1,2].map(i => ( <div key={i} className="bg-white 
          rounded-xl shadow p-6">
  return ( <div className="font-bold text-xl mb-2">عنوان الخبر {i}</div> <div className="text-gray-600 mb-3">2025-08-01</div> <div 
            className="text-gray-700 mb-2">نص مختصر للخبر أو التحديثات الجديدة بالمنصة...</div> <button className="text-blue-600 
            underline">اقرأ المزيد</button>
    <div className="max-w-4xl mx-auto mt-10"> </div> ))} <h1 className="text-3xl font-bold mb-6">الأخبار والفعاليات</h1> </div> <div 
      className="space-y-8"> </div>
        {articles.map(a=>( ); <Link to={`/news/${a.id}`} key={a.id} className="block bg-white rounded-2xl p-6 shadow hover:scale-105 
          duration-100">}
            <div className="flex items-center gap-4"> <img src={a.image || "/img/news_placeholder.jpg"} className="w-20 h-20 rounded-xl 
              object-cover"/> <div>
                <div className="font-bold text-lg">{a.title}</div> <div className="text-gray-400 text-sm">{a.date}</div> </div> </div> 
            <div className="mt-2">{a.summary}</div>
          </Link> ))} </div> </div> );
}
