<?php<?php

namespace App\Http\Controllers\Admin; namespace App\Http\Controllers\Admin; use App\Http\Controllers\Controller;

class AdminDashboardController extends Controller { use App\Http\Controllers\Controller; public function index() use 
Illuminate\Http\Request; { use App\Models\User; // TODO: Load admin dashboard data use App\Models\Event; return view('admin.dashboard'); 
// Create this Blade view use App\Models\Certificate; } use App\Models\Organization;} use App\Models\Partner; use App\Models\News; use 
App\Models\Kyc; use App\Models\VolunteerHour; use App\Models\Log; class AdminDashboardController extends Controller {
    public function index()
    {
        $totalUsers = User::count();
        $totalEvents = Event::count();
        $totalCertificates = Certificate::count();
        $totalOrganizations = Organization::count();
        $totalPartners = class_exists('\App\Models\Partner') ? Partner::count() : 0;
        $totalNews = class_exists('\App\Models\News') ? News::count() : 0;
        $totalKyc = class_exists('\App\Models\Kyc') ? Kyc::count() : 0;
        $totalVolunteerHours = class_exists('\App\Models\VolunteerHour') ? VolunteerHour::sum('hours') : 0;
        // Recent activities/logs - just as example, customize as needed
        $recentLogs = class_exists('\App\Models\Log') ? Log::latest()->limit(10)->get() : [];
        return view('admin.dashboard', compact(
            'totalUsers',
            'totalEvents',
            'totalCertificates',
            'totalOrganizations',
            'totalPartners',
            'totalNews',
            'totalKyc',
            'totalVolunteerHours',
            'recentLogs'
        ));
    }
}
